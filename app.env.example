# Copy this file outside the project, restrict it to the service account, and
# replace every placeholder before production use. The app does not load this
# file automatically; source it in the shell or pass it to Docker with --env-file.

NODE_ENV=production
HOST=0.0.0.0
PORT=8776

CONTEST_STORAGE=mysql
CONTEST_MYSQL_HOST=127.0.0.1
CONTEST_MYSQL_PORT=3306
CONTEST_MYSQL_DATABASE=campus_final_scoring
CONTEST_MYSQL_USER=contest_scoring
CONTEST_MYSQL_PASSWORD=replace-with-a-strong-server-only-password
CONTEST_MYSQL_TABLE_PREFIX=contest_final_
CONTEST_MYSQL_CONNECTION_LIMIT=5

CONTEST_REQUIRE_ADMIN_PASSWORD_ROTATION=1
CONTEST_LOG_DIR=/opt/campus-final-scoring/logs
